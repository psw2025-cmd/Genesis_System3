[flake8]
max-line-length = 120
exclude =
  .git,
  .venv,
  .pytest_cache,
  node_modules,
  tests/auto/system3_generated_tests,
  desktop_app/dist,
  desktop_app/build,
  desktop_app/.next,
  dashboard/frontend/dist,
  dashboard/frontend/node_modules

# Keep the signal-to-noise high for governance runs on a legacy codebase.
# We fail only on high-confidence correctness issues.
select =
  E9,
  F63,
  F7,
  F82

per-file-ignores =
  __init__.py:F401

