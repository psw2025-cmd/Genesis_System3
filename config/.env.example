# Genesis System3 - Environment Variables Example
# Copy to .secrets/dhan.env and fill in real values.
# DO NOT commit any file with real credentials to version control.

# ============================================================================
# DHAN BROKER CREDENTIALS (Required)
# ============================================================================
# DhanHQ client credentials — obtain from web.dhan.co → Profile → API
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_APP_ID=your_dhan_app_id_here
DHAN_APP_SECRET=your_dhan_app_secret_here

# Login PIN (4-6 digit numeric PIN used for token generation)
DHAN_PIN=your_pin_here

# TOTP secret (base32 string from authenticator app — for automated token refresh)
DHAN_TOTP_SECRET=your_totp_base32_secret_here

# Access token (auto-updated by dhan_token_auto_refresh.py at 08:30 IST)
# Leave blank on first setup; the refresh daemon will populate this.
DHAN_ACCESS_TOKEN=

# ============================================================================
# TRADING MODE (Safety Settings)
# ============================================================================
# System is ANALYZER ONLY by default.
# Do NOT set this to 1 unless all CI gates are green and live trading is authorized.
SYSTEM3_LIVE_TRADING_ALLOWED=0

# ============================================================================
# SYSTEM CONFIGURATION (Optional)
# ============================================================================
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_CONTINUOUS=1
