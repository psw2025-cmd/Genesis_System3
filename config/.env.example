# Genesis System3 - Environment Variables Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================================================
# ANGEL ONE BROKER CREDENTIALS (Required for live data)
# ============================================================================
# Get these from: https://smartapi.angelone.in/
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_ID=your_client_id_here
ANGELONE_PIN=your_pin_here
# OR use password instead of PIN:
# ANGELONE_PASSWORD=your_password_here

# TOTP Secret (from authenticator app)
# Format: Base32 encoded string (typically 16-32 characters)
ANGELONE_TOTP=your_totp_secret_here

# ============================================================================
# TRADING MODE (Safety Settings)
# ============================================================================
# Set to "1", "true", "yes", or "y" to enable live trading
# Default: disabled (paper trading only)
SYSTEM3_LIVE_TRADING_ALLOWED=0

# ============================================================================
# SYSTEM CONFIGURATION (Optional)
# ============================================================================
# Heartbeat interval in seconds (default: 60)
HEARTBEAT_INTERVAL_SECONDS=60

# Enable continuous heartbeat updates (default: 1)
HEARTBEAT_CONTINUOUS=1

# ============================================================================
# NOTES
# ============================================================================
# 1. All Angel One credentials are required for live market data
# 2. Without credentials, system will use synthetic data (market closed mode)
# 3. Live trading is disabled by default for safety
# 4. Never commit .env file to version control
