# System3 Ultra Dashboard Frontend
# Build stage
FROM node:20-alpine AS builder
WORKDIR /app

COPY dashboard/frontend/package*.json ./
RUN npm ci

COPY dashboard/frontend/ .
RUN npm run build

# Serve stage - use nginx to serve static files
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# Default nginx config serves from /usr/share/nginx/html
# API proxy: frontend calls backend at same origin or configured API_URL
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
