PROJECT_ROOT = Path(__file__).parent
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

# Import complete orchestrator (handles ALL phases 1-∞)
from system3_complete_orchestrator import CompleteOrchestrator

# Setup comprehensive logging
LOG_DIR = PROJECT_ROOT / "logs" / "ai_controller"
LOG_DIR.mkdir(parents=True, exist_ok=True)
LOG_FILE = LOG_DIR / f"ai_controller_{datetime.now().strftime('%Y%m%d')}.log"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] [%(name)s] %(message)s",
    handlers=[
        logging.FileHandler(LOG_FILE, encoding="utf-8"),
        logging.StreamHandler(),
    ],
)

logger = logging.getLogger("AIController")


class SystemState(Enum):
    """System operational states."""
    INITIALIZING = "initializing"
    PRE_MARKET = "pre_market"
    MARKET_HOURS = "market_hours"
    POST_MARKET = "post_market"
    MAINTENANCE = "maintenance"
    ERROR = "error"
    SHUTDOWN = "shutdown"


class DecisionEngine:
    """AI-powered decision making engine."""
    
    def __init__(self):
        self.state = SystemState.INITIALIZING
        self.last_decision = None
        self.decision_history = []
        
    def analyze_context(self) -> Dict[str, Any]:
        """Analyze current system context."""
        now = datetime.now()
        current_time = now.time()
        
        # Market hours detection
        market_start = dt_time(9, 15)
        market_end = dt_time(15, 30)
        pre_market_start = dt_time(7, 0)
        post_market_end = dt_time(18, 0)
        
        is_market_hours = market_start <= current_time <= market_end
        is_pre_market = pre_market_start <= current_time < market_start
        is_post_market = market_end < current_time <= post_market_end
        
        # Weekend detection
        is_weekend = now.weekday() >= 5  # Saturday=5, Sunday=6
        
        return {
            "timestamp": now.isoformat(),
            "current_time": current_time.isoformat(),
            "is_market_hours": is_market_hours,
            "is_pre_market": is_pre_market,
            "is_post_market": is_post_market,
            "is_weekend": is_weekend,
            "state": self.state.value,
        }
    
    def decide_action(self) -> Dict[str, Any]:
        """AI-powered decision making."""
        context = self.analyze_context()
        
        # Decision logic based on context
        action = {
            "timestamp": context["timestamp"],
            "context": context,
            "actions": [],
            "priority": "normal",
        }
        
        if context["is_weekend"]:
            action["actions"] = ["health_check", "log_cleanup", "maintenance"]
            action["priority"] = "low"
            self.state = SystemState.MAINTENANCE
            
        elif context["is_pre_market"]:
            action["actions"] = [
                "pre_market_validation",
                "health_check",
                "auto_heal",
                "threshold_check",
                "signal_dryrun",
            ]
            action["priority"] = "high"
            self.state = SystemState.PRE_MARKET
            
        elif context["is_market_hours"]:
            action["actions"] = [
                "monitor_trading",
                "auto_heal",
                "phase_execution",
                "signal_processing",
            ]
            action["priority"] = "critical"
            self.state = SystemState.MARKET_HOURS
            
        elif context["is_post_market"]:
            action["actions"] = [
                "eod_processing",
                "learning_update",
                "report_generation",
                "auto_heal",
                "archive_signals",
            ]
            action["priority"] = "high"
            self.state = SystemState.POST_MARKET
        else:
            action["actions"] = ["health_check", "auto_heal"]
            action["priority"] = "low"
            self.state = SystemState.MAINTENANCE
        
        self.last_decision = action
        self.decision_history.append(action)
        
        return action


class HealthMonitor:
    """Continuous health monitoring."""
    
    def __init__(self):
        self.health_score = 100
        self.issues = []
        
    def check_system_health(self) -> Dict[str, Any]:
        """Comprehensive health check."""
        health = {
            "timestamp": datetime.now().isoformat(),
            "checks": {},
            "overall_score": 0,
            "status": "unknown",
        }
        
        checks = []
        
        # Check 1: Heartbeat file
        try:
            heartbeat_file = PROJECT_ROOT / "system3_daily_heartbeat.json"
            if heartbeat_file.exists():
                with heartbeat_file.open("r") as f:
                    heartbeat = json.load(f)
                
                last_ts = datetime.fromisoformat(heartbeat.get("timestamp", datetime.now().isoformat()))
                age = (datetime.now() - last_ts).total_seconds()
                
                checks.append({
                    "name": "heartbeat",
                    "status": "healthy" if age < 600 else "warning",
                    "score": 100 if age < 600 else 50,
                })
            else:
                checks.append({"name": "heartbeat", "status": "missing", "score": 0})
        except Exception as e:
            checks.append({"name": "heartbeat", "status": "error", "score": 0, "error": str(e)})
        
        # Check 2: Staleness flags
        try:
            from core.engine.system3_phase306_staleness_guard import run_phase306
            result = run_phase306()
            expired_count = result.get("outputs", {}).get("expired_count", 0)
            
            checks.append({
                "name": "data_staleness",
                "status": "healthy" if expired_count == 0 else "warning",
                "score": 100 if expired_count == 0 else max(0, 100 - (expired_count * 20)),
                "expired_count": expired_count,
            })
        except Exception as e:
            checks.append({"name": "data_staleness", "status": "error", "score": 50, "error": str(e)})
        
        # Check 3: Disk space
        try:
            import shutil
            total, used, free = shutil.disk_usage(PROJECT_ROOT)
            free_gb = free / (1024 ** 3)
            
            checks.append({
                "name": "disk_space",
                "status": "healthy" if free_gb > 5 else "warning",
                "score": 100 if free_gb > 5 else max(0, int(free_gb / 5 * 100)),
                "free_gb": round(free_gb, 2),
            })
        except Exception as e:
            checks.append({"name": "disk_space", "status": "error", "score": 50, "error": str(e)})
        
        # Check 4: Process status (autorun, watchdog)
        process_checks = []
        for proc_name in ["python", "system3"]:
            try:
                # Simple check if processes exist
                process_checks.append({"name": proc_name, "status": "running"})
            except Exception:
                process_checks.append({"name": proc_name, "status": "unknown"})
        
        checks.append({
            "name": "processes",
            "status": "healthy",
            "score": 100,
            "details": process_checks,
        })
        
        # Calculate overall score
        health["checks"] = {check["name"]: check for check in checks}
        scores = [check["score"] for check in checks if "score" in check]
        health["overall_score"] = sum(scores) / len(scores) if scores else 0
        
        if health["overall_score"] >= 80:
            health["status"] = "healthy"
        elif health["overall_score"] >= 60:
            health["status"] = "warning"
        else:
            health["status"] = "critical"
        
        self.health_score = health["overall_score"]
        self.issues = [check for check in checks if check.get("status") not in ["healthy", "running"]]
        
        return health


class AutoExecutor:
    """Automatic task execution engine."""
    
    def __init__(self):
        self.execution_log = []
        self.running_processes = {}
        
        # Initialize Complete Orchestrator (handles ALL phases 1-∞)
        logger.info("🔌 Initializing Complete Orchestrator...")
        self.orchestrator = CompleteOrchestrator()
        if self.orchestrator.initialize():
            logger.info("   ✅ Complete Orchestrator ready (ALL phases 1-∞)")
        else:
            logger.error("   ❌ Failed to initialize Complete Orchestrator")
            self.orchestrator = None
        
    def execute_pre_market_checks(self) -> bool:
        """Execute comprehensive pre-market validation."""
        logger.info("🔍 Running pre-market checks...")
        
        checks = [
            {
                "name": "threshold_validation",
                "script": "core/validation/validate_live_thresholds.py",
                "critical": True,
            },
            {
                "name": "signal_dryrun",
                "script": "core/validation/pre_market_signal_dryrun.py",
                "critical": True,
            },
            {
                "name": "signal_engine_test",
                "script": "core/engine/system3_signal_engine_self_test.py",
                "critical": True,
            },
            {
                "name": "phase_validation",
                "script": "system3_phases_301_310_diagnostics.py",
                "critical": False,
            },
        ]
        
        results = []
        for check in checks:
            try:
                logger.info(f"  ▸ {check['name']}...")
                result = subprocess.run(
                    [sys.executable, check["script"]],
                    cwd=PROJECT_ROOT,
                    capture_output=True,
                    timeout=60,
                )
                
                success = result.returncode == 0
                results.append({
                    "name": check["name"],
                    "success": success,
                    "critical": check["critical"],
                })
                
                if success:
                    logger.info(f"    ✅ {check['name']} passed")
                else:
                    logger.warning(f"    ⚠️  {check['name']} failed")
                    if check["critical"]:
                        logger.error(f"    ❌ Critical check failed - cannot proceed")
                        return False
                        
            except Exception as e:
                logger.error(f"    ❌ {check['name']} error: {e}")
                if check["critical"]:
                    return False
                results.append({
                    "name": check["name"],
                    "success": False,
                    "critical": check["critical"],
                    "error": str(e),
                })
        
        # All critical checks passed
        passed = sum(1 for r in results if r["success"])
        total = len(results)
        logger.info(f"✅ Pre-market checks complete: {passed}/{total} passed")
        
        return all(r["success"] for r in results if r["critical"])
    
    def start_autorun_master(self) -> Optional[subprocess.Popen]:
        """Start autorun master process."""
        try:
            logger.info("🚀 Starting autorun master...")
            
            process = subprocess.Popen(
                [sys.executable, "system3_autorun_master.py"],
                cwd=PROJECT_ROOT,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            
            self.running_processes["autorun_master"] = process
            logger.info(f"✅ Autorun master started (PID: {process.pid})")
            return process
            
        except Exception as e:
            logger.error(f"❌ Failed to start autorun master: {e}")
            return None
    
    def start_watchdog(self) -> Optional[subprocess.Popen]:
        """Start watchdog process."""
        try:
            logger.info("🐕 Starting watchdog...")
            
            process = subprocess.Popen(
                [sys.executable, "system3_watchdog.py"],
                cwd=PROJECT_ROOT,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            
            self.running_processes["watchdog"] = process
            logger.info(f"✅ Watchdog started (PID: {process.pid})")
            return process
            
        except Exception as e:
            logger.error(f"❌ Failed to start watchdog: {e}")
            return None
    
    def start_auto_heal_scheduler(self) -> Optional[subprocess.Popen]:
        """Start auto-heal scheduler."""
        try:
            logger.info("🔧 Starting auto-heal scheduler...")
            
            process = subprocess.Popen(
                [sys.executable, "system3_auto_heal_scheduler.py"],
                cwd=PROJECT_ROOT,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            
            self.running_processes["auto_heal"] = process
            logger.info(f"✅ Auto-heal scheduler started (PID: {process.pid})")
            return process
            
        except Exception as e:
            logger.error(f"❌ Failed to start auto-heal scheduler: {e}")
            return None
    
    def execute_complete_orchestration_cycle(self) -> bool:
        """Execute complete orchestration cycle (ALL phases 1-∞)."""
        if not self.orchestrator:
            logger.error("  ❌ Complete Orchestrator not available")
            return False
        
        try:
            result = self.orchestrator.execute_full_cycle()
            return result.get("tier2_status") != "FAILED" and result.get("tier3_status") != "FAILED"
        except Exception as e:
            logger.error(f"  ❌ Failed to execute orchestration cycle: {e}")
            return False
    
    def execute_action(self, action: str) -> bool:
        """Execute a specific action."""
        logger.info(f"▸ Executing: {action}")
        
        action_map = {
            "pre_market_validation": self.execute_pre_market_checks,
            "health_check": lambda: HealthMonitor().check_system_health(),
            "auto_heal": lambda: subprocess.run([sys.executable, "-m", "core.engine.system3_auto_heal_orchestrator"], cwd=PROJECT_ROOT, timeout=300),
            "monitor_trading": lambda: logger.info("  Monitoring active (handled by complete orchestrator)"),
            "phase_execution": lambda: self.execute_complete_orchestration_cycle(),
            "phase_execution_all": lambda: self.execute_complete_orchestration_cycle(),
            "signal_processing": lambda: logger.info("  Signal processing active (Tier 1 - Core)"),
            "eod_processing": lambda: self.execute_complete_orchestration_cycle(),
            "learning_update": lambda: logger.info("  Learning update (Tier 1 - Core)"),
            "report_generation": lambda: subprocess.run([sys.executable, "system3_ultra_daily_runner.py"], cwd=PROJECT_ROOT, timeout=600),
            "archive_signals": lambda: logger.info("  Signal archival (handled by complete orchestrator)"),
            "log_cleanup": lambda: subprocess.run([sys.executable, "-m", "core.engine.system3_auto_heal_orchestrator"], cwd=PROJECT_ROOT, timeout=300),
            "maintenance": lambda: logger.info("  System maintenance mode"),
            "threshold_check": lambda: subprocess.run([sys.executable, "core/validation/validate_live_thresholds.py"], cwd=PROJECT_ROOT, timeout=60),
            "signal_dryrun": lambda: subprocess.run([sys.executable, "core/validation/pre_market_signal_dryrun.py"], cwd=PROJECT_ROOT, timeout=60),
        }
        
        try:
            if action in action_map:
                result = action_map[action]()
                logger.info(f"  ✅ {action} completed")
                return True
            else:
        action_map = {
            "pre_market_validation": self.execute_pre_market_checks,
            "health_check": lambda: HealthMonitor().check_system_health(),
            "auto_heal": lambda: subprocess.run([sys.executable, "-m", "core.engine.system3_auto_heal_orchestrator"], cwd=PROJECT_ROOT, timeout=300),
            "monitor_trading": lambda: logger.info("  Monitoring active (handled by complete orchestrator)"),
            "phase_execution": lambda: self.execute_complete_orchestration_cycle(),
            "phase_execution_all": lambda: self.execute_complete_orchestration_cycle(),
            "signal_processing": lambda: logger.info("  Signal processing active (Tier 1 - Core)"),
            "eod_processing": lambda: self.execute_complete_orchestration_cycle(),
            "learning_update": lambda: logger.info("  Learning update (Tier 1 - Core)"),
            "report_generation": lambda: subprocess.run([sys.executable, "system3_ultra_daily_runner.py"], cwd=PROJECT_ROOT, timeout=600),
            "archive_signals": lambda: logger.info("  Signal archival (handled by complete orchestrator)"),
            "log_cleanup": lambda: subprocess.run([sys.executable, "-m", "core.engine.system3_auto_heal_orchestrator"], cwd=PROJECT_ROOT, timeout=300),
            "maintenance": lambda: logger.info("  System maintenance mode"),
            "threshold_check": lambda: subprocess.run([sys.executable, "core/validation/validate_live_thresholds.py"], cwd=PROJECT_ROOT, timeout=60),
            "signal_dryrun": lambda: subprocess.run([sys.executable, "core/validation/pre_market_signal_dryrun.py"], cwd=PROJECT_ROOT, timeout=60),
        }elf.start_time = datetime.now()
        
        logger.info("=" * 80)
        logger.info("🧠 ULTIMATE AI CONTROLLER - INITIALIZING")
        logger.info("=" * 80)
        logger.info(f"Start Time: {self.start_time.strftime('%Y-%m-%d %H:%M:%S')}")
        logger.info(f"Mode: FULLY AUTONOMOUS")
        logger.info("=" * 80)
    
    def initialize_system(self) -> bool:
        """Initialize all system components."""
        logger.info("\n📋 SYSTEM INITIALIZATION")
        logger.info("-" * 80)
        
        # Step 1: Health check
        logger.info("1️⃣  Running initial health check...")
        health = self.health_monitor.check_system_health()
        logger.info(f"   Health Score: {health['overall_score']:.1f}/100")
        logger.info(f"   Status: {health['status'].upper()}")
        
        if health["status"] == "critical":
            logger.error("   ❌ System health critical - running auto-heal...")
            self.executor.execute_action("auto_heal")
            
            # Re-check health
            health = self.health_monitor.check_system_health()
            if health["status"] == "critical":
                logger.error("   ❌ System still critical after healing - manual intervention may be needed")
                return False
        
        # Step 2: Context analysis
        logger.info("\n2️⃣  Analyzing system context...")
        context = self.decision_engine.analyze_context()
        logger.info(f"   Current State: {self.decision_engine.state.value}")
        logger.info(f"   Market Hours: {context['is_market_hours']}")
        logger.info(f"   Pre-Market: {context['is_pre_market']}")
        logger.info(f"   Weekend: {context['is_weekend']}")
        
        # Step 3: Pre-market checks (if applicable)
        if context["is_pre_market"] or context["is_market_hours"]:
            logger.info("\n3️⃣  Running pre-market validation...")
            if not self.executor.execute_pre_market_checks():
                logger.error("   ❌ Pre-market checks failed - cannot start trading")
                return False
            logger.info("   ✅ Pre-market validation passed")
        
        logger.info("\n✅ SYSTEM INITIALIZATION COMPLETE")
        logger.info("-" * 80)
        return True
    
    def start_core_services(self) -> bool:
        """Start all core services."""
        logger.info("\n🚀 STARTING CORE SERVICES")
        logger.info("-" * 80)
        
        # Start auto-heal scheduler (always running)
        logger.info("1️⃣  Auto-Heal Scheduler...")
        self.executor.start_auto_heal_scheduler()
        time.sleep(2)
        
        # Start watchdog (always running)
        logger.info("\n2️⃣  Watchdog Monitor...")
        self.executor.start_watchdog()
        time.sleep(2)
        
        # Start autorun master (during market hours)
        context = self.decision_engine.analyze_context()
        if context["is_market_hours"] or context["is_pre_market"]:
            logger.info("\n3️⃣  Autorun Master (Trading Mode)...")
            self.executor.start_autorun_master()
            time.sleep(2)
        else:
            logger.info("\n3️⃣  Autorun Master (Skipped - outside market hours)")
        
        logger.info("\n✅ CORE SERVICES STARTED")
        logger.info("-" * 80)
        return True
    
    def run_autonomous_loop(self):
        """Main autonomous control loop."""
        logger.info("\n🤖 ENTERING AUTONOMOUS CONTROL LOOP")
        logger.info("=" * 80)
        logger.info("System is now fully autonomous. All decisions are automatic.")
        logger.info("Press Ctrl+C to stop.")
        logger.info("=" * 80)
        
        self.running = True
        cycle = 0
        
        try:
            while self.running:
                cycle += 1
                logger.info(f"\n🔄 AUTONOMOUS CYCLE #{cycle}")
                logger.info("-" * 80)
                
                # Step 1: Health check
                health = self.health_monitor.check_system_health()
                logger.info(f"Health: {health['status'].upper()} ({health['overall_score']:.1f}/100)")
                
                # Step 2: Decision making
                decision = self.decision_engine.decide_action()
                logger.info(f"State: {decision['context']['state']}")
                logger.info(f"Priority: {decision['priority'].upper()}")
                logger.info(f"Actions: {len(decision['actions'])}")
                
                # Step 3: Execute actions
                for action in decision["actions"]:
                    self.executor.execute_action(action)
                
                # Step 4: Process monitoring
                for name, process in self.executor.running_processes.items():
                    if process and process.poll() is not None:
                        logger.warning(f"⚠️  Process {name} has stopped (exit code: {process.returncode})")
                        # Auto-restart logic
                        if name == "watchdog":
                            logger.info(f"🔄 Restarting {name}...")
                            self.executor.start_watchdog()
                        elif name == "auto_heal":
                            logger.info(f"🔄 Restarting {name}...")
                            self.executor.start_auto_heal_scheduler()
                
                # Step 5: Sleep based on priority
                if decision["priority"] == "critical":
                    sleep_time = 60  # 1 minute during market hours
                elif decision["priority"] == "high":
                    sleep_time = 300  # 5 minutes during pre/post market
                else:
                    sleep_time = 1800  # 30 minutes during maintenance
                
                logger.info(f"💤 Next cycle in {sleep_time} seconds...")
                time.sleep(sleep_time)
                
        except KeyboardInterrupt:
            logger.info("\n\n⚠️  SHUTDOWN SIGNAL RECEIVED")
            self.running = False
        except Exception as e:
            logger.error(f"\n\n❌ CRITICAL ERROR: {e}")
            logger.error(f"Traceback: {traceback.format_exc()}")
            self.running = False
    
    def shutdown(self):
        """Graceful shutdown."""
        logger.info("\n🛑 INITIATING GRACEFUL SHUTDOWN")
        logger.info("=" * 80)
        
        # Terminate all child processes
        for name, process in self.executor.running_processes.items():
            if process and process.poll() is None:
                logger.info(f"Stopping {name} (PID: {process.pid})...")
                try:
                    process.terminate()
                    process.wait(timeout=10)
                    logger.info(f"  ✅ {name} stopped")
                except Exception as e:
                    logger.warning(f"  ⚠️  Force killing {name}: {e}")
                    process.kill()
        
        # Save final state
        uptime = (datetime.now() - self.start_time).total_seconds()
        logger.info(f"\nUptime: {uptime / 3600:.2f} hours")
        logger.info(f"Decisions Made: {len(self.decision_engine.decision_history)}")
        logger.info(f"Final Health Score: {self.health_monitor.health_score:.1f}/100")
        
        logger.info("\n✅ SHUTDOWN COMPLETE")
        logger.info("=" * 80)
    
    def run(self):
        """Main entry point - run the complete system."""
        try:
            # Initialize
            if not self.initialize_system():
                logger.error("❌ Initialization failed - aborting")
                return 1
            
            # Start services
            if not self.start_core_services():
                logger.error("❌ Failed to start services - aborting")
                return 1
            
            # Run autonomous loop
            self.run_autonomous_loop()
            
            return 0
            
        except Exception as e:
            logger.error(f"❌ FATAL ERROR: {e}")
            return 1
        finally:
            self.shutdown()


def main():
    """Main entry point."""
    import traceback
    
    controller = UltimateAIController()
    
    try:
        exit_code = controller.run()
        sys.exit(exit_code)
    except Exception as e:
        logger.error(f"UNHANDLED EXCEPTION: {e}")
        logger.error(traceback.format_exc())
        sys.exit(1)


if __name__ == "__main__":
    main()
